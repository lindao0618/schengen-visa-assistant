// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String // For credentials provider
  role          String    @default("user") // 用户角色: user, admin
  status        String    @default("active") // active, inactive, banned
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  applications      Application[]
  documents         Document[]
  applicantProfiles ApplicantProfile[]
  usVisaTasks       UsVisaTask[]
  frenchVisaTasks   FrenchVisaTask[]
  visaCases         VisaCase[]
  assignedVisaCases VisaCase[]        @relation("VisaCaseAssignee")
  reminderLogs      ReminderLog[]
}

// 签证申请模型
model Application {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  visaType  String // 签证类型
  status    String // 申请状态
  country   String // 申请国家
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]
  reviews   Review[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

// 文档模型
model Document {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String // 文档类型 (hotel, flight, insurance, etc)
  filename      String
  fileUrl       String
  status        String // 文档状态
  aiAnalysis    String?     @db.Text // AI分析结果，可能较长
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  reviews       Review[]

  @@index([userId])
  @@index([applicationId])
  @@index([userId, status])
  @@index([applicationId, status])
}

// 审核记录模型
model Review {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  result        String      @db.Text // 审核结果，可能较长
  feedback      String      @db.Text // 审核反馈，可能较长
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
  @@index([documentId])
  @@index([applicationId, documentId])
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApplicantProfile {
  id                   String   @id
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  phone                String?
  email                String?
  wechat               String?
  passportNumber       String?
  passportLast4        String?
  note                 String?  @db.Text
  usVisaAaCode         String?
  usVisaSurname        String?
  usVisaBirthYear      String?
  usVisaPassportNumber String?
  usVisaSlotTime       DateTime?
  schengenCountry      String?
  schengenVisaCity     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  files           ApplicantFile[]
  usVisaTasks     UsVisaTask[]
  frenchVisaTasks FrenchVisaTask[]
  visaCases       VisaCase[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([userId, name])
  @@index([phone])
  @@index([email])
  @@index([passportNumber])
}

model ApplicantFile {
  id                 String           @id @default(cuid())
  applicantProfileId String
  applicantProfile   ApplicantProfile @relation(fields: [applicantProfileId], references: [id], onDelete: Cascade)
  slot               String
  originalName       String
  storedName         String
  relativePath       String
  mimeType           String
  size               Int
  uploadedAt         DateTime         @default(now())

  @@unique([applicantProfileId, slot])
  @@index([applicantProfileId])
}

// 美签任务模型（持久化）
model UsVisaTask {
  id                 String            @id @default(cuid())
  taskId             String            @unique // 如 task-xxx
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicantProfileId String?
  applicantProfile   ApplicantProfile? @relation(fields: [applicantProfileId], references: [id], onDelete: SetNull)
  type               String // check-photo | fill-ds160 | submit-ds160 | register-ais
  status             String // pending | running | completed | failed
  progress           Int               @default(0)
  message            String            @default("")
  result             Json? // { files, aaCode, emailSent, ... }
  error              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([applicantProfileId])
  @@index([userId, applicantProfileId, createdAt])
}

// 法签任务模型（持久化）
model FrenchVisaTask {
  id                 String            @id @default(cuid())
  taskId             String            @unique
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicantProfileId String?
  applicantProfile   ApplicantProfile? @relation(fields: [applicantProfileId], references: [id], onDelete: SetNull)
  type               String // extract | register | create-application | fill-receipt | submit-final
  status             String // pending | running | completed | failed
  progress           Int               @default(0)
  message            String            @default("")
  result             Json? // { download_excel, download_json, download_pdf, ... }
  error              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([applicantProfileId])
  @@index([userId, applicantProfileId, createdAt])
}

// 管理后台设置
model VisaCase {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicantProfileId String
  applicantProfile   ApplicantProfile @relation(fields: [applicantProfileId], references: [id], onDelete: Cascade)
  caseType           String           @default("france-schengen")
  visaType           String?
  applyRegion        String?
  tlsCity            String?
  bookingWindow      String?
  acceptVip          String?
  slotTime           DateTime?
  mainStatus         String
  subStatus          String?
  exceptionCode      String?
  priority           String           @default("normal")
  travelDate         DateTime?
  submissionDate     DateTime?
  assignedToUserId   String?
  assignedTo         User?            @relation("VisaCaseAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  assignedRole       String?
  isActive           Boolean          @default(true)
  paymentConfirmedAt DateTime?
  formSubmittedAt    DateTime?
  docsReadyAt        DateTime?
  slotBookedAt       DateTime?
  submittedAt        DateTime?
  completedAt        DateTime?
  nextActionAt       DateTime?
  closedAt           DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  statusHistory VisaCaseStatusHistory[]
  reminderLogs  ReminderLog[]

  @@index([userId, caseType, isActive])
  @@index([applicantProfileId, caseType, isActive])
  @@index([userId, mainStatus, updatedAt])
  @@index([userId, applicantProfileId, updatedAt])
  @@index([assignedToUserId])
  @@index([visaType, applyRegion])
}

model VisaCaseStatusHistory {
  id             String   @id @default(cuid())
  caseId         String
  visaCase       VisaCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromMainStatus String?
  fromSubStatus  String?
  toMainStatus   String
  toSubStatus    String?
  exceptionCode  String?
  reason         String?
  operatorType   String   @default("system")
  operatorId     String?
  createdAt      DateTime @default(now())

  @@index([caseId, createdAt])
  @@index([toMainStatus, createdAt])
}

model ReminderRule {
  id              String   @id @default(cuid())
  ruleCode        String   @unique
  name            String
  enabled         Boolean  @default(true)
  caseType        String   @default("france-schengen")
  mainStatus      String?
  subStatus       String?
  exceptionCode   String?
  triggerType     String
  triggerValue    Json?
  delayMinutes    Int      @default(0)
  channels        String[]
  automationMode  String
  severity        String
  templateCode    String
  cooldownMinutes Int      @default(0)
  stopCondition   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reminderLogs ReminderLog[]

  @@index([caseType, enabled])
  @@index([caseType, mainStatus, subStatus])
  @@index([caseType, exceptionCode])
}

model ReminderLog {
  id              String        @id @default(cuid())
  caseId          String
  visaCase        VisaCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  ruleId          String?
  rule            ReminderRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleCode        String
  channel         String
  automationMode  String
  severity        String
  templateCode    String
  renderedContent String?       @db.Text
  sendStatus      String        @default("pending")
  errorMessage    String?       @db.Text
  triggeredAt     DateTime      @default(now())
  sentAt          DateTime?
  createdAt       DateTime      @default(now())

  @@index([caseId, triggeredAt])
  @@index([userId, triggeredAt])
  @@index([ruleCode, triggeredAt])
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// 内容管理
model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
