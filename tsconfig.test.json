{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".test-dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "lib/health.ts",
    "lib/applicant-initial-material-upload.ts",
    "lib/applicant-schedule-view.ts",
    "lib/generated-filename.ts",
    "lib/schengen-excel-audit.ts",
    "lib/us-visa-excel-autofix.ts",
    "lib/us-visa-interview-brief.ts"
  ],
  "exclude": [
    "node_modules",
    ".test-dist"
  ]
}
