# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/.next-build/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files（保留 .env.example 作为模板）
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temp (包括任务持久化文件等)
/temp/

# 本地调试导出（HTML/JSON 可能含个人信息）
/debug-dumps/
/.playwright-mcp/
/.test-dist/
/AA*.png
/error_*.png
/error_html_*.html
/initial_html_*.html
/initial_page_*.png

# IDE / 编辑器
.cursor/
/.vscode/

# 日志与缓存
*.log
logs/
slots_cache.json

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/

