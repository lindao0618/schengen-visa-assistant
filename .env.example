# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth
NEXTAUTH_SECRET="replace_with_a_long_random_secret"
NEXTAUTH_URL="http://localhost:3000"

# Email
SMTP_HOST="smtp.163.com"
SMTP_PORT=465
SMTP_USER="your@example.com"
SMTP_PASSWORD="your_smtp_password"

# Captcha
CAPTCHA_API_KEY="your_2captcha_api_key"

# AI / OCR
DEEPSEEK_API_KEY="your_deepseek_api_key"
TENCENTCLOUD_SECRET_ID="your_tencent_secret_id"
TENCENTCLOUD_SECRET_KEY="your_tencent_secret_key"

# Internal service URLs
TRIP_GENERATOR_URL="http://127.0.0.1:8002"
EXPLANATION_LETTER_URL="http://127.0.0.1:8003"
MATERIAL_REVIEW_URL="http://127.0.0.1:8004"
TLS_MONITOR_URL="http://127.0.0.1:8005"

# Optional runtime tuning
DS160_TIMING=0
SELENIUM_HEADLESS=true

# WeCom Drive
WECOM_CORP_ID="wwxxxxxxxxxxxxxxxx"
WECOM_AGENT_SECRET="replace_with_wecom_agent_secret"
WECOM_DRIVE_ROOTS_JSON='[{"id":"clients","label":"客户材料总目录","spaceId":"SPACEID","fatherId":"FATHERID"}]'
